//Modifique el programa anterior para que imprima la tabla de multiplicar completa del 1 al 10.
#include <iostream>
using namespace std;

int main() {
    cout << "=== TABLAS DE MULTIPLICAR DEL 1 AL 10 ===\n\n";

    // El primer bucle controla el número de la tabla (del 1 al 10)
    for (int i = 1; i <= 10; i++) {
        cout << "--- Tabla del " << i << " ---\n";
        
        // El segundo bucle realiza las multiplicaciones del 1 al 10
        for (int j = 1; j <= 10; j++) {
            cout << i << " x " << j << " = " << (i * j) << "\n";
        }
        cout << "\n"; // Deja un espacio en blanco entre tablas para que se vea ordenado
    }

    return 0;
}
