//Hacer un programa que calcule el factorial de todos los números hasta un número dado por teclado.
#include <iostream>
using namespace std;

int main() {
    int limite;
    cout << "Introduce un numero entero positivo: ";
    cin >> limite;

    // Recorremos todos los números desde el 1 hasta el límite dado
    for (int i = 1; i <= limite; i++) {
        long long factorial = 1; // Usamos long long porque el factorial crece rápido
        
        // Calculamos el factorial del número actual 'i'
        for (int j = 1; j <= i; j++) {
            factorial = factorial * j;
        }
        
        cout << "El factorial de " << i << " es: " << factorial << "\n";
    }

    return 0;
}
