//Construya un programa que imprima la suma de los cuadrados de los 100 primeros números naturales.
#include <iostream>
using namespace std;

int main() {
    int suma = 0;

    // Un bucle del 1 al 100
    for (int i = 1; i <= 100; i++) {
        suma = suma + (i * i); // Multiplicamos el número por sí mismo y lo acumulamos
    }

    cout << "La suma de los cuadrados de los 100 primeros numeros es: " << suma << "\n";

    return 0;
}
