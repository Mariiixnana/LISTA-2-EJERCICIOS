//Se desea calcular independiente la suma de los números pares e impares comprendidos entre 1 y 200.
#include <iostream>
using namespace std;

int main() {
    int sumaPares = 0;
    int sumaImpares = 0;

    for (int i = 1; i <= 200; i++) {
        if (i % 2 == 0) {
            sumaPares = sumaPares + i; // Si el residuo es cero, es par
        } else {
            sumaImpares = sumaImpares + i; // Si no, es impar
        }
    }

    cout << "La suma de los 200 primeros numeros pares es: " << sumaPares << "\n";
    cout << "La suma de los 200 primeros numeros impares es: " << sumaImpares << "\n";

    return 0;
}
